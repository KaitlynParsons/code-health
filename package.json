{
  "name": "CodeHealthJS",
  "displayName": "codehealth.js",
  "description": "Your ultimate code health visibility tool to help prevent software entropy.",
  "publisher": "kaitlynparsons",
  "icon": "media/icon.png",
  "author": {
    "name": "Kaitlyn Parsons"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KaitlynParsons/code-health"
  },
  "license": "MIT",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Linters"
  ],
  "keywords": [
    "productivity",
    "typescript",
    "javascript",
    "code quality",
    "static analysis",
    "technical debt",
    "code metrics",
    "linting",
    "software entropy"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "code-health-sidebar",
          "title": "Code Health",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "code-health-sidebar": [
        {
          "type": "webview",
          "id": "code-health-sidebar",
          "name": "Code Health",
          "icon": "media/icon.png"
        }
      ]
    },
    "commands": [],
    "configuration": {
      "title": "Code Health",
      "properties": {
        "codehealth": {
          "type": "object",
          "default": {},
          "properties": {
            "entry": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Entry point file paths (glob patterns) passed to fallow for dead code analysis. Exports in these files are treated as used, so fallow won't report them as unused."
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "bundledDependencies": [
    "esbuild",
    "fallow",
    "oxlint"
  ],
  "dependencies": {
    "esbuild": "^0.28.1",
    "fallow": "^2.103.0",
    "oxlint": "^1.72.0"
  }
}
